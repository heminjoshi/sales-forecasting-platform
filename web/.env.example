# Base URL of the read API the SPA calls. Build-time injected by Vite (VITE_ prefix => exposed to
# the client bundle). This is a PUBLIC API host, not a secret.
#
# Local dev (Spring Boot on 8080):
VITE_API_BASE=http://localhost:8080
#
# On Vercel, set VITE_API_BASE in the project's Environment Variables to the deployed API origin
# (which must allow-list this SPA's origin via CORS — see web/README.md).
#
# Leaving it empty makes all requests relative (same-origin) — useful only if the SPA is ever
# served from the same host as the API.
